rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Catch-All Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    // Checks if the user is authenticated with a verified email
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the current user profile exists and retrieve it
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Role-checking helpers using the secure DB user document
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserDoc().role == 'Admin';
    }

    function isStakeholder() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserDoc().role == 'Stakeholder';
    }

    function isUserOfEmail(email) {
      return request.auth.token.email == email;
    }

    function hasValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Safe payload state grabbers
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }


    // --- Collection Routes ---

    // 1. Users Collection
    match /users/{userId} {
      // Admins can do everything. Users can read their own profile, and can create/update basic details upon registration under strict rules.
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
      
      // Admin is authorized to write any profile. A new user can register themselves only if setting their own uid, active status, and default or assigned parameters.
      allow create: if isSignedIn() && (
        isAdmin() || (
          request.auth.uid == userId && 
          incoming().userId == request.auth.uid && 
          incoming().email == request.auth.token.email &&
          (incoming().role == 'Sub-stakeholder' || !incoming().keys().hasAll(['role'])) && // Can't auto-appoint admin or stakeholder
          incoming().active == true
        )
      );

      allow update: if isSignedIn() && (
        isAdmin() || (
          request.auth.uid == userId && 
          incoming().userId == userId &&
          incoming().email == existing().email &&
          incoming().role == existing().role && // Prevent upgrading role
          incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'managerEmail', 'teamId', 'updatedAt'])
        )
      );

      allow delete: if isAdmin();
    }

    // 2. Teams
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 3. Live Tasks Collection
    match /tasks/{taskId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        existing().assignedTo == request.auth.token.email ||
        existing().assignedBy == request.auth.token.email ||
        (isStakeholder() && existing().teamId == getUserDoc().teamId)
      );

      // Creation gates for Tasks
      allow create: if isSignedIn() && (
        isAdmin() || (
          isStakeholder() && 
          incoming().teamId == getUserDoc().teamId && 
          incoming().assignedBy == request.auth.token.email &&
          hasValidId(taskId)
        )
      );

      // Tiered update gates
      allow update: if isSignedIn() && (
        isAdmin() || (
          // Stakeholders can modify task specifications within team scope
          isStakeholder() && 
          existing().teamId == getUserDoc().teamId &&
          incoming().teamId == existing().teamId &&
          incoming().assignedBy == existing().assignedBy
        ) || (
          // Sub-stakeholders / Assignee can ONLY update status progress and reports summary
          existing().assignedTo == request.auth.token.email &&
          incoming().assignedTo == existing().assignedTo &&
          incoming().title == existing().title &&
          incoming().description == existing().description &&
          incoming().priority == existing().priority &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'percentComplete', 'lastReportSummary', 'closeRemark', 'completionDate', 'updatedAt'])
        )
      );

      allow delete: if isAdmin();
    }

    // 4. Task Templates Collection
    match /taskTemplates/{templateId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        existing().assignedBy == request.auth.token.email ||
        (isStakeholder() && existing().teamId == getUserDoc().teamId)
      );

      allow create: if isSignedIn() && (
        isAdmin() || (
          isStakeholder() && 
          incoming().teamId == getUserDoc().teamId &&
          incoming().assignedBy == request.auth.token.email &&
          hasValidId(templateId)
        )
      );

      allow update: if isSignedIn() && (
        isAdmin() || (
          isStakeholder() && 
          existing().teamId == getUserDoc().teamId && 
          incoming().teamId == existing().teamId &&
          incoming().assignedBy == existing().assignedBy
        )
      );

      allow delete: if isAdmin() || (
        isStakeholder() && 
        existing().teamId == getUserDoc().teamId
      );
    }

    // 5. Reports Subcollection
    match /taskReports/{reportId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        existing().submittedBy == request.auth.token.email ||
        (isStakeholder()) // Stakeholders can read status reports of team scope tasks
      );

      allow create: if isSignedIn() && (
        isAdmin() || 
        incoming().submittedBy == request.auth.token.email
      );

      allow update, delete: if isAdmin();
    }

    // 6. Follow-ups
    match /followUps/{followUpId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        existing().createdBy == request.auth.token.email ||
        isStakeholder()
      );

      allow create: if isSignedIn() && (
        isAdmin() || 
        incoming().createdBy == request.auth.token.email
      );

      allow update, delete: if isAdmin();
    }

    // 7. Audit logs
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn(); // Allow triggers and actions to post audit logs safely
      allow update, delete: if false;
    }
  }
}
